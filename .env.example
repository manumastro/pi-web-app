# Pi Web App - Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3210
NODE_ENV=development

# Sessions storage
SESSIONS_DIR=~/.pi/agent/sessions

# SDK Configuration
SDK_CWD=/home/manu
SDK_MODEL=claude-3-5-sonnet-20241022

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3211,http://localhost:5173

# Logging
LOG_LEVEL=info

# Frontend cache persistence (localStorage)
# Default is disabled; set true only for explicit opt-in.
VITE_ENABLE_FRONTEND_CACHE=false

# Frontend HTTP cache headers served by backend static host
# Default is true (send no-store headers on dist/public assets + index.html)
PI_WEB_DISABLE_FRONTEND_HTTP_CACHE=true
