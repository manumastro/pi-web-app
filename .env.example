# Port for the web server (default: 3210)
PI_WEB_PORT=3210

# Authentication token for WebSocket connections
# If set, clients must connect with ?token=YOUR_TOKEN
# Leave empty to disable authentication
PI_WEB_AUTH_TOKEN=

# Idle timeout for pi processes in milliseconds
# If set, pi processes are killed after being idle (no connected clients) for this duration
# Set to 0 to disable (keep processes alive forever)
PI_WEB_IDLE_TIMEOUT_MS=300000

# Working directory for pi sessions (default: $HOME)
PI_WEB_CWD=/home/manu
