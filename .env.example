# Pi Web App - Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3210
NODE_ENV=development

# Sessions storage
SESSIONS_DIR=~/.pi/agent/sessions

# SDK Configuration
SDK_CWD=/home/manu
SDK_MODEL=claude-3-5-sonnet-20241022

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3211,http://localhost:5173

# Logging
LOG_LEVEL=info
