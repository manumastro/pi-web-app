{
  "name": "pi-web-app",
  "version": "0.2.0",
  "type": "module",
  "description": "Pi Web — AI Coding Agent nel Browser (RPC Bridge)",
  "scripts": {
    "start": "npx tsx src/server.ts",
    "dev:server": "npx tsx --watch src/server.ts",
